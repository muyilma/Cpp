      "updated": 1784548427273,
      "link": null,
      "locked": false,
      "text": "1.döngü ilk giriş[(42, 5), (15, 10), (88, 3), (25, 2)]----------------------------------- \n\nleft=(42, 5), (15, 10);\nright=(88, 3), (25, 2);\nsort_vector(left); 1.dögü sonu\n\n2.döngü[(42, 5), (15, 10)]--------------------------------------------\n\nleft=(42, 5);\nright=(15, 10);\nsort_vector(left); 2.dögü sonu\n\n3.döngü[(42, 5)]-------------------------------------------------\n\nif (_vect.size() <= 1)\n        return; // 3.döngü sonu\n\n2.döngü devam-----------------------------------------------------\nsort_vector(right); // 2.döngü devam sonu\n \n\n4.döngü [(15, 10)]------------------------------------------------------\n\nif (_vect.size() <= 1)\n        return; //4.döngü sonu\n\n2.döngü devam v2--------------------------------------------------------\n// debug left=(42, 5); right=(15, 10);\n\nif(42 <= 15)\n _vect[k++] = left[i++]; // (42,5) = (42,5) buraya girmez\n        else\n _vect[k++] = right[j++]; // (42,5) = (15,10) buraya girer\n\n    while (i < left.size()) // 0 < 1\n        _vect[k++] = left[i++]; //(15,10) = (42,5) leftin devamı yoktu diye \n    while (j < right.size())// 1 < 1\n     _vect[k++] = right[j++]; //15,10 = NULL rightın devamında bir şey yok tekti zaten\n//scop sonu 2.döngü biter \n\n1.döngü devam ----------------------------------------------------\n    sort_vector(right); 1.döngü devam sonu\n\n2.döngü yeni [(88, 3), (25, 2)]------------------------------------------------\n\n left=(88, 3);\nright=(25, 2);\n\nsort_vector(left);  2.döngi yeni sonu\n\n3.döngü[(88, 3)]-----------------------------------------\n\nif (_vect.size() <= 1)\n        return; //3.döngü sonu\n\n2.döngü devam--------------------------\n\nsort_vector(right);  2.döngi devam sonu\n\n4.döngü[(25, 2)]---------------------------------------------\n\nif (_vect.size() <= 1)\n        return; //4.döngü sonu\n\n2.döngü devam v2-------------------------------------\n// debug left=(88, 3); right=(25, 2);\n\nif(88 <= 25)\n _vect[k++] = left[i++]; //(88, 3) = (88, 3)buraya girmez\n        else\n _vect[k++] = right[j++]; // (88, 3) = (25, 2) buraya girer\n\n    while (i < left.size()) // 0 < 1\n        _vect[k++] = left[i++]; //(25, 2)= (88, 3) leftin devamı yoktu diye \n    while (j < right.size())// 1 < 1\n     _vect[k++] = right[j++]; //(25, 2)= NULL rightın devamında bir şey yok tekti zaten\n//scop sonu 2.döngü biter \n\n1.döngü devam v2 \n// debug  left=(15, 10),(42, 5) ; right=(25, 2), (88, 3);\n//burda kafam karıştı aslında 1.döngüye geri döndük ama değerler değişti recursive yaparken ben de değişen hallerini geri koydum acama ilk hallerini mi koymalıydım  left=(42, 5), (15, 10); right=(88, 3), (25, 2);\n\nif(15 <= 25)\n _vect[k++] = left[i++]; // (15, 10) = (15, 10) buraya girer zaten değiştirmiştik bu değeri recursive yaparken\n        else\n _vect[k++] = right[j++]; // (15, 10) = (25, 2) buraya girmez\ni=1\nif(42 <= 25)\n _vect[k++] = left[i++]; // (42, 5) = (42, 5) buraya girmez\n _vect[k++] = right[j++]; // (42, 5) = (25, 2) buraya girer\nj=1\n\nif(42 <= 88)\n _vect[k++] = left[i++]; //  (25, 2) = (42, 5) buraya girer\n _vect[k++] = right[j++]; // (25, 2) = (88, 3) buraya girmez\ni=2\n\nwhile (i < left.size()) // 2  < 2 \n    _vect[k++] = left[i++]; //(88, 3) = NULL boştur diye düşünüyorum \nwhile (j < right.size()) // 1 < 2\n _vect[k++] = right[j++];// (88, 3) = (88, 3) buraya girer\n\n//1.döngu sonu\n\n_vect = (15, 10), (25, 2), (42, 5), (88, 3); son Hali",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1.döngü ilk giriş[(42, 5), (15, 10), (88, 3), (25, 2)]----------------------------------- \n\nleft=(42, 5), (15, 10);\nright=(88, 3), (25, 2);\nsort_vector(left); 1.dögü sonu\n\n2.döngü[(42, 5), (15, 10)]--------------------------------------------\n\nleft=(42, 5);\nright=(15, 10);\nsort_vector(left); 2.dögü sonu\n\n3.döngü[(42, 5)]-------------------------------------------------\n\nif (_vect.size() <= 1)\n        return; // 3.döngü sonu\n\n2.döngü devam-----------------------------------------------------\nsort_vector(right); // 2.döngü devam sonu\n \n\n4.döngü [(15, 10)]------------------------------------------------------\n\nif (_vect.size() <= 1)\n        return; //4.döngü sonu\n\n2.döngü devam v2--------------------------------------------------------\n// debug left=(42, 5); right=(15, 10);\n\nif(42 <= 15)\n _vect[k++] = left[i++]; // (42,5) = (42,5) buraya girmez\n        else\n _vect[k++] = right[j++]; // (42,5) = (15,10) buraya girer\n\n    while (i < left.size()) // 0 < 1\n        _vect[k++] = left[i++]; //(15,10) = (42,5) leftin devamı yoktu diye \n    while (j < right.size())// 1 < 1\n     _vect[k++] = right[j++]; //15,10 = NULL rightın devamında bir şey yok tekti zaten\n//scop sonu 2.döngü biter \n\n1.döngü devam ----------------------------------------------------\n    sort_vector(right); 1.döngü devam sonu\n\n2.döngü yeni [(88, 3), (25, 2)]------------------------------------------------\n\n left=(88, 3);\nright=(25, 2);\n\nsort_vector(left);  2.döngi yeni sonu\n\n3.döngü[(88, 3)]-----------------------------------------\n\nif (_vect.size() <= 1)\n        return; //3.döngü sonu\n\n2.döngü devam--------------------------\n\nsort_vector(right);  2.döngi devam sonu\n\n4.döngü[(25, 2)]---------------------------------------------\n\nif (_vect.size() <= 1)\n        return; //4.döngü sonu\n\n2.döngü devam v2-------------------------------------\n// debug left=(88, 3); right=(25, 2);\n\nif(88 <= 25)\n _vect[k++] = left[i++]; //(88, 3) = (88, 3)buraya girmez\n        else\n _vect[k++] = right[j++]; // (88, 3) = (25, 2) buraya girer\n\n    while (i < left.size()) // 0 < 1\n        _vect[k++] = left[i++]; //(25, 2)= (88, 3) leftin devamı yoktu diye \n    while (j < right.size())// 1 < 1\n     _vect[k++] = right[j++]; //(25, 2)= NULL rightın devamında bir şey yok tekti zaten\n//scop sonu 2.döngü biter \n\n1.döngü devam v2 \n// debug  left=(15, 10),(42, 5) ; right=(25, 2), (88, 3);\n//burda kafam karıştı aslında 1.döngüye geri döndük ama değerler değişti recursive yaparken ben de değişen hallerini geri koydum acama ilk hallerini mi koymalıydım  left=(42, 5), (15, 10); right=(88, 3), (25, 2);\n\nif(15 <= 25)\n _vect[k++] = left[i++]; // (15, 10) = (15, 10) buraya girer zaten değiştirmiştik bu değeri recursive yaparken\n        else\n _vect[k++] = right[j++]; // (15, 10) = (25, 2) buraya girmez\ni=1\nif(42 <= 25)\n _vect[k++] = left[i++]; // (42, 5) = (42, 5) buraya girmez\n _vect[k++] = right[j++]; // (42, 5) = (25, 2) buraya girer\nj=1\n\nif(42 <= 88)\n _vect[k++] = left[i++]; //  (25, 2) = (42, 5) buraya girer\n _vect[k++] = right[j++]; // (25, 2) = (88, 3) buraya girmez\ni=2\n\nwhile (i < left.size()) // 2  < 2 \n    _vect[k++] = left[i++]; //(88, 3) = NULL boştur diye düşünüyorum \nwhile (j < right.size()) // 1 < 2\n _vect[k++] = right[j++];// (88, 3) = (88, 3) buraya girer\n\n//1.döngu sonu\n\n_vect = (15, 10), (25, 2), (42, 5), (88, 3); son Hali",
