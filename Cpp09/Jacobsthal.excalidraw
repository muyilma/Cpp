      "updated": 1784548279856,
      "link": null,
      "locked": false,
      "text": "\nvoid PmergeMe::sort_vector(std::vector< std::pair<int, int> > &_vect)\n{\n\n    \n    if (_vect.size() <= 1)\n        return;\n\n    int mid = _vect.size() / 2;\n    std::vector< std::pair<int, int> > left(_vect.begin(), _vect.begin() + mid);\n    std::vector< std::pair<int, int> > right(_vect.begin() + mid, _vect.end());\n\n    sort_vector(left);\n    sort_vector(right);\n\n    size_t i = 0, j = 0, k = 0;\n    while (i < left.size() && j < right.size()) {\n        if (left[i].first <= right[j].first)\n            _vect[k++] = left[i++];\n        else\n            _vect[k++] = right[j++];\n    }\n\n    while (i < left.size()) \n        _vect[k++] = left[i++];\n    while (j < right.size()) \n     _vect[k++] = right[j++];\n}",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nvoid PmergeMe::sort_vector(std::vector< std::pair<int, int> > &_vect)\n{\n\n    \n    if (_vect.size() <= 1)\n        return;\n\n    int mid = _vect.size() / 2;\n    std::vector< std::pair<int, int> > left(_vect.begin(), _vect.begin() + mid);\n    std::vector< std::pair<int, int> > right(_vect.begin() + mid, _vect.end());\n\n    sort_vector(left);\n    sort_vector(right);\n\n    size_t i = 0, j = 0, k = 0;\n    while (i < left.size() && j < right.size()) {\n        if (left[i].first <= right[j].first)\n            _vect[k++] = left[i++];\n        else\n            _vect[k++] = right[j++];\n    }\n\n    while (i < left.size()) \n        _vect[k++] = left[i++];\n    while (j < right.size()) \n     _vect[k++] = right[j++];\n}",
      "autoResize": true,
      "lineHeight": 1.35
    },
    {
      "id": "18_BLUjvPBbt30uNll15r",
      "type": "text",
      "x": 2638.3690553695415,
